{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PMXT",
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#0B0B0B",
    "light": "#FAFAFA",
    "dark": "#0B0B0B"
  },
  "api": {
    "examples": {
      "languages": [
        "python",
        "javascript",
        "curl",
        "go",
        "java"
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "claude",
      "chatgpt",
      "cursor"
    ],
    "display": "header"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://pmxt.dev/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://pmxt.dev/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "mcp",
              "security",
              "rate-limits",
              "sql"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/unified-schema",
              "concepts/catalog-vs-live",
              "concepts/venues"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/server"
            ]
          }
        ]
      },
      {
        "tab": "Router",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "router/overview"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "router/events",
              "router/markets"
            ]
          },
          {
            "group": "Analyze",
            "pages": [
              "router/event-matching",
              "router/matching",
              "router/prices"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "System",
            "pages": [
              "GET /health",
              "POST /api/{exchange}/loadMarkets",
              "POST /api/{exchange}/close"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Events & Markets",
            "pages": [
              "api-reference/fetch-events",
              "GET /api/{exchange}/fetchEventsPaginated",
              "api-reference/fetch-event",
              "api-reference/fetch-markets",
              "GET /api/{exchange}/fetchMarketsPaginated",
              "api-reference/fetch-market"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Order Book & Trades",
            "pages": [
              "api-reference/fetch-ohlcv",
              "api-reference/fetch-order-book",
              "POST /api/{exchange}/fetchOrderBooks",
              "GET /api/{exchange}/fetchTrades",
              "POST /api/{exchange}/getExecutionPrice",
              "POST /api/{exchange}/getExecutionPriceDetailed"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Trading",
            "pages": [
              "POST /api/{exchange}/createOrder",
              "POST /api/{exchange}/buildOrder",
              "POST /api/{exchange}/submitOrder",
              "POST /api/{exchange}/cancelOrder"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Orders & Positions",
            "pages": [
              "GET /api/{exchange}/fetchOrder",
              "GET /api/{exchange}/fetchOpenOrders",
              "GET /api/{exchange}/fetchMyTrades",
              "GET /api/{exchange}/fetchClosedOrders",
              "GET /api/{exchange}/fetchAllOrders",
              "GET /api/{exchange}/fetchPositions",
              "GET /api/{exchange}/fetchBalance"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Realtime",
            "pages": [
              "api-reference/websocket",
              "api-reference/watch-all-order-books",
              "api-reference/watch-order-book",
              "api-reference/watch-order-books",
              "api-reference/watch-trades"
            ]
          },
          {
            "group": "Data Feeds",
            "pages": [
              "GET /api/feeds",
              "GET /api/feeds/{feed}/loadMarkets",
              "GET /api/feeds/{feed}/fetchTicker",
              "GET /api/feeds/{feed}/fetchTickers",
              "GET /api/feeds/{feed}/fetchOHLCV",
              "GET /api/feeds/{feed}/fetchOrderBook",
              "GET /api/feeds/{feed}/watchTicker",
              "GET /api/feeds/{feed}/fetchOracleRound",
              "GET /api/feeds/{feed}/fetchOracleHistory",
              "GET /api/feeds/{feed}/fetchHistoricalPrices"
            ],
            "openapi": "api-reference/openapi.json"
          },
          {
            "group": "Cross Exchange",
            "openapi": "api-reference/openapi-hosted.json",
            "pages": [
              "GET /v0/matched-event-clusters",
              "GET /v0/matched-market-clusters"
            ]
          },
          {
            "group": "Enterprise",
            "openapi": "api-reference/openapi-hosted.json",
            "pages": [
              "sql",
              "POST /v0/sql"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pmxt-dev/pmxt"
    }
  }
}
