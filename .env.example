# Polymarket
POLYMARKET_PRIVATE_KEY=       # Ethereum private key for signing transactions
POLYMARKET_API_KEY=           # CLOB API key (from Polymarket developer portal)
POLYMARKET_API_SECRET=        # CLOB API secret
POLYMARKET_PASSPHRASE=        # CLOB API passphrase
POLYMARKET_FUNDER_ADDRESS=    # Proxy/funder address (optional)
POLYMARKET_SIGNATURE_TYPE=    # Signature type (optional, default: gnosis-safe)

# Polymarket US
POLYMARKET_US_KEY_ID=         # Polymarket US key ID
POLYMARKET_US_SECRET_KEY=     # Polymarket US secret key

# Kalshi
KALSHI_API_KEY=               # Kalshi API key
KALSHI_PRIVATE_KEY=           # Kalshi RSA private key (base64 or file path)

# Limitless
LIMITLESS_PRIVATE_KEY=        # Ethereum private key for signing transactions
LIMITLESS_API_KEY=            # CLOB API key
LIMITLESS_API_SECRET=         # CLOB API secret
LIMITLESS_PASSPHRASE=         # CLOB API passphrase

# Probable
PROBABLE_API_KEY=             # Probable API key
PROBABLE_API_SECRET=          # Probable API secret
PROBABLE_PASSPHRASE=          # Probable passphrase
PROBABLE_PRIVATE_KEY=         # Probable private key

# Myriad
MYRIAD_API_KEY=               # Myriad API key
MYRIAD_WALLET_ADDRESS=        # Myriad wallet address

# Baozi
BAOZI_PRIVATE_KEY=            # Baozi private key

# Opinion
OPINION_API_KEY=              # Opinion API key
OPINION_PRIVATE_KEY=          # Opinion private key

# Metaculus
METACULUS_API_TOKEN=          # Metaculus API token

# Smarkets
SMARKETS_EMAIL=               # Smarkets account email
SMARKETS_PASSWORD=            # Smarkets account password

# Hyperliquid
HYPERLIQUID_WALLET_ADDRESS=   # Hyperliquid wallet address
HYPERLIQUID_PRIVATE_KEY=      # Hyperliquid private key

# Gemini Titan
GEMINI_API_KEY=               # Gemini API key
GEMINI_API_SECRET=            # Gemini API secret

# OutLayer integration (custody + EVM signing; see OUTLAYER_INTEGRATION_PLAN.md)
OUTLAYER_ENABLED=             # "true" to route Polymarket through OutLayer in single-tenant/dev
OUTLAYER_API_BASE=            # default https://api.outlayer.fastnear.com
OUTLAYER_ACCOUNT_ID=          # app NEAR account id authorizing evm_sign (per-request override: credentials.outlayerAccountId)
OUTLAYER_NEAR_PRIVATE_KEY=    # ed25519:<base58> app signing key — SERVER-SIDE ONLY, never in credentials
OUTLAYER_VAULT_ID=            # optional sovereign vault id
OUTLAYER_SEED=                # single-tenant seed (multi-tenant: credentials.outlayerSeed / outlayerUserId)
OUTLAYER_USER_ID=             # single-tenant convenience: seed = sha256("predict:user:<id>")
OUTLAYER_WK_KEY=             # zero-NEAR-key alt: a registered "wk_…" custody-wallet key (single-tenant/dev); near: preferred for multi-tenant
OUTLAYER_SIGNER=              # "local" forces LocalKeySigner (offline tests only); default = live OutlayerSigner
OUTLAYER_LOCAL_PRIVATE_KEY=   # 0x… secp256k1 key for OUTLAYER_SIGNER=local (else a throwaway is generated)
POLYGON_RPC_URL=              # broadcaster RPC (default https://polygon-rpc.com)
POLYGON_RELAYER_PRIVATE_KEY=  # 0x… key that pays gas for the gasless EIP-3009 exit (Phase 2)

# Optional
LOG_LEVEL=                    # debug, info, warn, error (default: info)
PMXT_ALWAYS_RESTART=          # Set to 1 to force server restart on every SDK call
