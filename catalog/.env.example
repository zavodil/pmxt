# --- server ---
PORT=8080
CORS_ORIGINS=*                 # comma-separated frontend origins, or * for dev
RATE_LIMIT_MAX=120             # requests/min/IP

# --- database (Postgres + pgvector) ---
# Set a STRONG password (e.g. `openssl rand -hex 24`). Compose substitutes it into both
# the db container and the api's DATABASE_URL. Keep the two below in sync.
POSTGRES_PASSWORD=change-me-openssl-rand-hex-24
DATABASE_URL=postgres://catalog:change-me-openssl-rand-hex-24@localhost:5432/catalog

# --- pmxt sidecar (read-only HTTP source; the pmxt server listens on :3847) ---
PMXT_BASE_URL=http://localhost:3847
# pmxt requires this token (header x-pmxt-access-token). Start pmxt with the SAME value:
#   PMXT_ACCESS_TOKEN=... npm run server   (else it generates a random one in ~/.pmxt/server.lock)
PMXT_ACCESS_TOKEN=

# --- ingest ---
VENUE_ALLOWLIST=polymarket     # comma-separated; v1 = polymarket only
INGEST_CRON=0 * * * *          # hourly metadata refresh (node-cron syntax)
INGEST_MIN_VOLUME=0            # drop markets with volume24h below this (dust filter)
INGEST_PAGE_LIMIT=100000       # single-fetch cap (pmxt returns the full active set at once)
INGEST_ENABLED=true            # set false to run the API without the in-process cron

# --- embeddings (semantic search). Set provider=none to run keyword-only ---
EMBEDDINGS_PROVIDER=none       # none | voyage | openai
EMBED_MODEL=voyage-3-lite      # voyage-3-lite | text-embedding-3-small | ...
EMBED_DIM=1024                 # voyage-3-lite=1024, openai 3-small=1536 — MUST match the vector(N) column
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- discover LLM rerank: OpenAI-compatible endpoint (POST {AI_BASE_URL}/chat/completions) ---
# Set the trio (base+key+model) to enable LLM rerank; leave unset for keyword-only retrieval order.
# Local-claude proxy (see ../../ai-intents/RUNNING.md): base http://127.0.0.1:8317/v1, key = proxy bearer.
AI_BASE_URL=http://127.0.0.1:8317/v1
AI_API_KEY=                    # the proxy's local Bearer password (NOT an Anthropic API key)
AI_MODEL=claude-sonnet-4-5-20250929   # or claude-opus-4-5-20250729 / claude-haiku-4-5-20250729
DISCOVER_RETRIEVE_K=40         # candidates fused before the LLM rerank

# --- inbound auth (gates our endpoints; unrelated to AI_API_KEY) ---
DISCOVER_API_KEY=             # if set, /v1/markets/discover requires header x-api-key
ADMIN_API_KEY=               # if set, /v1/admin/ingest requires header x-admin-key
