{
  "name": "pmxt-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prediction-market catalog web service (Skyscanner for predictions). Consumes pmxt over HTTP; upstream-clean.",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "ingest": "tsx src/ingest/cron.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
