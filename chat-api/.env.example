# --- server ---
PORT=8090
CORS_ORIGINS=*

# --- database (shares the catalog Postgres instance; own tables) ---
DATABASE_URL=postgres://catalog:CHANGE_ME@localhost:5432/catalog

# --- upstream services ---
CATALOG_BASE_URL=http://localhost:8080      # the catalog service (discover/search/quote)
DEFAULT_VENUE=polymarket

# --- LLM (OpenAI-compatible; local-claude proxy in dev) ---
AI_BASE_URL=http://127.0.0.1:8317/v1
AI_API_KEY=                                  # proxy bearer
AI_MODEL=claude-sonnet-4-5-20250929
AGENT_MAX_STEPS=6
AGENT_TEMPERATURE=0.3

# --- auth (wallet login → JWT). The userId (e.g. evm:0x..) is the OutLayer derivation root. ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long

# --- betting (the USDC/OutLayer flow). Keep OFF until wired to real custody ---
BET_EXECUTION_ENABLED=false
